# Server
PORT=8080

# Database (Render / PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/kpfl
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT (base64 secret, at least 32 bytes before encoding)
JWT_SECRET=REPLACE_WITH_BASE64_SECRET
JWT_ACCESS_EXPIRATION_MS=86400000

# TheSportsDB sync
THESPORTSDB_ENABLED=true
THESPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json/123
THESPORTSDB_LEAGUE_ID=4969
THESPORTSDB_SYNC_CRON=0 0 */2 * * *
THESPORTSDB_TIMEZONE=UTC

# JVM tuning (optional)
JAVA_OPTS=-Xms256m -Xmx512m
